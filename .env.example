# Vexel Health Platform — Environment Variables Template
# Copy to .env and fill in real values. Never commit .env to source control.

# JWT signing secret — MUST be replaced in production.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET=REPLACE_WITH_64_BYTE_HEX_SECRET

# Required in production for ops backup env encryption.
BACKUP_PASSPHRASE=

# Restore stays disabled by default. Set true only for controlled staging drills.
VEXEL_ALLOW_RESTORE=false

# Retention window for local backup artifacts.
OPS_BACKUP_RETENTION_DAYS=30
